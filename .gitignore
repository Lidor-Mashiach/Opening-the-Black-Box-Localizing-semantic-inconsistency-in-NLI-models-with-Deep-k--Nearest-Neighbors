# ---------- Python ----------
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.ipynb_checkpoints/

# ---------- Heavy, fully-reproducible artifacts ----------
# fine-tuned checkpoints (Step-1)
**/results/checkpoints/
*.safetensors
*.pt
*.ckpt

# ALL run-derived data (reduced copies, encodings, per-model paraphrase
# copies) - wiped and rebuilt every run; only the README is tracked
Runtime-Data/*
!Runtime-Data/README.md

# ---------- Models: backbones IN the project, weights kept local ----------
# The pretrained backbones downloaded from HuggingFace live in the project,
# but the weights are heavy - keep them local. The folder + its README are
# tracked so a fresh clone has the structure; the tuned CONFIGS
# (configs/tuned/, light) ARE committed so no machine needs to re-run Optuna.
Models/raw/*
!Models/raw/.gitkeep

# raw dataset dumps (re-download with Datasets/download_datasets.py)
Datasets/*/raw/*
!Datasets/*/raw/.keep

# paraphrase-bank working artifacts (the bank itself IS tracked)
Datasets/*/paraphrases/paraphrase_bank.backup.csv
Datasets/*/paraphrases/paraphrase_bank.tmp.csv

# ---------- Caches / tools ----------
.cache/
wandb/
.huggingface/

# ---------- OS / editors ----------
.DS_Store
Thumbs.db
.idea/
.vscode/

# ---------- Tuning artifacts ----------
tuning/results/**/optuna.db

# ---------- Research results ----------
# Per-run archives + the cross-run summary ARE tracked by default, so a
# GitHub push captures your findings. They are small (CSVs + PNGs). To keep
# them local instead, uncomment:
# Research-Pipeline/PhaseA/Step-4_Consistency-and-Diagnosis/results/runs/
# Research-Pipeline/PhaseA/Step-4_Consistency-and-Diagnosis/results/runs_summary.csv
